{
  "name": "gps-camera",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --host 0.0.0.0 --port 8000",
    "web": "npm run dev",
    "test:unit": "tsc -p tsconfig.tests.json && node --test .tmp-tests/tests/**/*.test.js",
    "typecheck": "tsc --noEmit --pretty false",
    "build:web": "vite build",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173",
    "build": "npm run typecheck && npm run build:web"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "typescript": "5.9.3",
    "vite": "7.3.0"
  }
}
